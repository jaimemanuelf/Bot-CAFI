# ============================================================
#  CAFI Bot — Variables de Entorno
#  Copia este archivo como `.env` y rellena cada valor.
#  NUNCA subas tu archivo `.env` real al repositorio.
# ============================================================

# ----------------------------------------------------------
# TELEGRAM
# ----------------------------------------------------------
# Token que BotFather te entrega al crear el bot.
# Ejemplo: 123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# ID numérico de tu cuenta de Telegram (único usuario autorizado).
# Puedes obtenerlo enviando /start al bot @userinfobot.
# Ejemplo: 987654321
ALLOWED_USER_ID=tu_user_id_de_telegram_aqui

# ----------------------------------------------------------
# GROQ  (https://console.groq.com)
# ----------------------------------------------------------
# API Key de Groq para el LLM que procesa texto e imágenes.
# Ejemplo: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=tu_api_key_de_groq_aqui

# ----------------------------------------------------------
# GOOGLE DRIVE  (opcional — para sincronización automática)
# ----------------------------------------------------------
# Estas credenciales se generan desde Google Cloud Console.
# Descarga el archivo OAuth 2.0 como `credentials.json`
# y colócalo en la raíz del proyecto.
# El archivo `token.json` se crea automáticamente al autenticarte
# por primera vez; ambos están ignorados por .gitignore.
#
# No se requiere ninguna variable de entorno adicional para Drive;
# solo asegúrate de tener credentials.json en la raíz.

# ----------------------------------------------------------
# PERSONALIZACIÓN  (opcional)
# ----------------------------------------------------------
# Nombre del dueño del bot, usado en los prompts del LLM.
# Si no se define, se usará "el usuario" por defecto.
OWNER_NAME=tu_nombre_aqui
